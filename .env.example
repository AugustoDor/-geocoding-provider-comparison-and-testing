# Mapbox Search Box API
# Docs:    https://docs.mapbox.com/api/search/search-box/
# Console: https://account.mapbox.com/
# Steps:   Sign up → Dashboard → Tokens → Create a token (Public token works)
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# HERE Geocoding & Search API
# Docs:    https://developer.here.com/documentation/geocoding-search-api/
# Console: https://platform.here.com/portal/
# Steps:   Sign up → Projects → Create API key → Copy it here
# Free tier: 30,000 requests/month
HERE_API_KEY=your_here_api_key_here

# Google Places API
# Docs:    https://developers.google.com/maps/documentation/places/web-service/autocomplete
# Console: https://console.cloud.google.com/
# Steps:   Create project → Enable "Places API" → Credentials → Create API key
# Note:    Requires a billing account but has a $200/month free credit
GOOGLE_API_KEY=your_google_api_key_here
